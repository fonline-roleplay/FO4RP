import bool WASDInputKeyState(int key, bool state) from "input_wasd";

const string[] MainGroupsList = {"Main", "RTS", "WASD", "GM", "GMRTS", "GMWASD"};
const string[] GMGroupsList = {"GM", "GMRTS", "GMWASD"};
const string[] WASDGroupsList = {"WASD", "GMWASD"};

// KeyCode enum from input_wasd.fos
enum WASDKeyCode
{
    W = 0x11,
    A = 0x1E,
    S = 0x1F,
    D = 0x20,

    LShift = 0x2A,
}

// APAMk2 TO APAmk2: Redo this shit, make all callbacks to have their own last call time, to determine if we can (or can't) execute it again
uint LastLayerChangeTime = 0;

import void SwitchCraftScreen() from "client_screen_fixboy";

bool AimCallback(int state, int[] args)
{
	if(state != KEY_PRESS) return false;

	if( !__ConsoleActive )
	{				
		RunServerScriptUnsafe( "main@unsafe_set_aim", args[0], 0, 0, null, null );
	}

	return false;
}

