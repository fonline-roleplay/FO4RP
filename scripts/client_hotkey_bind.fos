	ChangeViewBorder();
	
	return false;
}

// FOR DEVELOPER TESTS ONLY, DO NOT LEAVE ANY CRITICAL CODE HERE - APAMk2
bool TestDeveloperKeyCallback(int state, int[] args)
{
	if(__ConsoleActive) return false;
	if(state != KEY_PRESS) return false;

	int activeScr = GUI_GetActiveScreen();
	Message("Pressed" + activeScr);

	if(activeScr != CLIENT_SCREEN_INVENTORY)
	{
		Message("Show" + activeScr);
		ShowScreen( CLIENT_SCREEN_INVENTORY, 0, 0, 0 );
	}
	else
	{
		Message("Hide" + activeScr);
		HideScreen( CLIENT_SCREEN_INVENTORY, 0, 0, 0);
	}
	
	return false;
}

void AddMultigroupHotkey(string[] groupList, string name, uint8[] keys, HotkeyOnKeyState@ callback, int[] args, int flags)
{
	if(!valid(groupList))
	{
		Log("Can't add hotkey to multiple groups: group List is invalid");
		return;
	}

	for(uint i = 0, len = groupList.length(); i < len; i++)
	{
		HotkeyMngr_AddHotkey(groupList[i], name, keys, callback, args, flags);
	}
}

void AddMultigroupHotkey(string[] groupList, string name, uint8[] keys, HotkeyOnKeyState@ callback, int[] args)
{
	AddMultigroupHotkey(groupList, name, keys, callback, args, 0);
}

void AddMultigroupHotkey(string[] groupList, string name, uint8 key, HotkeyOnKeyState@ callback, int[] args)
{
	AddMultigroupHotkey(groupList, name, array<uint8> = {key}, callback, args, 0);
}

void AddMultigroupHotkey(string[] groupList, string name, uint8[] keys, HotkeyOnKeyState@ callback)
{
	AddMultigroupHotkey(groupList, name, keys, callback, array<int>(), 0);
}

void AddMultigroupHotkey(string[] groupList, string name, uint8 key, HotkeyOnKeyState@ callback)
{
	AddMultigroupHotkey(groupList, name, array<uint8> = {key}, callback, array<int>(), 0);
}

void AddMultigroupHotkey(string[] groupList, string name, uint8 key, HotkeyOnKeyState@ callback, int[] args, int flags)
{
	AddMultigroupHotkey(groupList, name, array<uint8> = {key}, callback, args, flags);
}

void AddMultigroupHotkey(string[] groupList, string name, uint8[] keys, HotkeyOnKeyState@ callback, int flags)
{
	AddMultigroupHotkey(groupList, name, keys, callback, array<int>(), flags);
}

void AddMultigroupHotkey(string[] groupList, string name, uint8 key, HotkeyOnKeyState@ callback, int flags)
{
	AddMultigroupHotkey(groupList, name, array<uint8> = {key}, callback, array<int>(), flags);
}

