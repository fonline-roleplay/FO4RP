	return false;
}

bool SwitchScreenCallback(int state, int[] args)
{
	if(__ConsoleActive) return false;
	if(state != KEY_PRESS) return false;

	int activeScr = GUI_GetActiveScreen();

	if(activeScr != args[0] && (activeScr == CLIENT_MAIN_SCREEN_GAME || activeScr == CLIENT_MAIN_SCREEN_GLOBAL_MAP))
	{
		ShowScreen( args[0], 0, 0, 0 );
	}
	else if(activeScr == args[0])
	{
		HideScreen( args[0], 0, 0, 0);
	}
	
	return false;
}

bool ShowCritIDCallback(int state, int[] args)
{
	if(__ConsoleActive) return false;
	if(state != KEY_PRESS) return false;

	if(__DebugInfo)
		__ShowCritId = !__ShowCritId;
	
	return false;
}

bool SwitchCharScreenCallback(int state, int[] args)
{
	if(__ConsoleActive) return false;
	if(state != KEY_PRESS) return false;

	CritterCl@ chosen = GetChosen();
	if(!valid(chosen)) return false;

	int activeScr = GUI_GetActiveScreen();

	if(activeScr != CLIENT_SCREEN_CHARACTER && (activeScr == CLIENT_MAIN_SCREEN_GAME || activeScr == CLIENT_MAIN_SCREEN_GLOBAL_MAP))
	{
		ShowScreen( CLIENT_SCREEN_CHARACTER, 0, 0, 0 );
		if(chosen.Param[ ST_UNSPENT_PERKS ] > 0)
			ShowScreen( CLIENT_SCREEN_PERK, 0, 0, 0 );
	}
	else if(activeScr == CLIENT_SCREEN_CHARACTER)
	{
		HideScreen( CLIENT_SCREEN_CHARACTER, 0, 0, 0);
	}
	
	return false;
}

bool ChangeViewBorderCallback(int state, int[] args)
