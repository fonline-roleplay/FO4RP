bool WASDKeyPressCallback(int state, int[] args)
{
	if(__ConsoleActive) return false;

	CritterCl@ chosen = GetChosen();
	if(!valid(chosen)) return false;
	if(!FLAG( chosen.Param[ PLAYER_FLAGS ], PLAYER_FLAG_WSAD ) || (FLAG( chosen.Param[ PLAYER_FLAGS ], PLAYER_FLAG_RTS ) && __mobhotkeys)) return false;

	if(state == KEY_PRESS)
	{
		return WASDInputKeyState(args[0], true);
	}
	if(state == KEY_RELEASE)
	{
		return WASDInputKeyState(args[0], false);
	}

	return true;
}

