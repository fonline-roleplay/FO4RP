void SwitchHotkeyLayer(int layer)
{
	LastLayerChangeTime = GetTick();
	if(layer == LAYER_AUTODETECT)
	{
		layer = __mobhotkeys ? LAYER_GM : LAYER_NORMAL;
		CritterCl@ chosen = GetChosen();

		if(valid(chosen))
		{
			if( FLAG( chosen.Param[ PLAYER_FLAGS ], PLAYER_FLAG_WSAD ) ) layer = __mobhotkeys ? LAYER_GMWASD : LAYER_WASD;
			if( FLAG( chosen.Param[ PLAYER_FLAGS ], PLAYER_FLAG_RTS ) ) layer = __mobhotkeys ? LAYER_GMRTS : LAYER_RTS;
		}
	}

	if(__mobhotkeys)
	{
		if( layer == LAYER_NORMAL) layer = LAYER_GM;
		if( layer == LAYER_RTS ) layer = LAYER_GMRTS;
		if( layer == LAYER_WASD ) layer = LAYER_GMWASD;
	}

	switch(layer)
	{
	case LAYER_NORMAL:
	{
		HotkeyMngr_SetGroupState("Main", true);
		HotkeyMngr_SetGroupState("RTS", false);
		HotkeyMngr_SetGroupState("WASD", false);
		HotkeyMngr_SetGroupState("GM", false);
		HotkeyMngr_SetGroupState("GMRTS", false);
		HotkeyMngr_SetGroupState("GMWASD", false);
	}
	break;
	case LAYER_RTS:
	{
		HotkeyMngr_SetGroupState("RTS", true);
		HotkeyMngr_SetGroupState("Main", false);
		HotkeyMngr_SetGroupState("WASD", false);
		HotkeyMngr_SetGroupState("GM", false);
		HotkeyMngr_SetGroupState("GMRTS", false);
		HotkeyMngr_SetGroupState("GMWASD", false);
	}
	break;
	case LAYER_WASD:
	{
		HotkeyMngr_SetGroupState("WASD", true);
		HotkeyMngr_SetGroupState("Main", false);
		HotkeyMngr_SetGroupState("RTS", false);
		HotkeyMngr_SetGroupState("GM", false);
		HotkeyMngr_SetGroupState("GMRTS", false);
		HotkeyMngr_SetGroupState("GMWASD", false);
	}
	break;
	case LAYER_GM:
	{
		HotkeyMngr_SetGroupState("GM", true);
		HotkeyMngr_SetGroupState("GMRTS", false);
		HotkeyMngr_SetGroupState("GMWASD", false);
		HotkeyMngr_SetGroupState("Main", false);
		HotkeyMngr_SetGroupState("RTS", false);
		HotkeyMngr_SetGroupState("WASD", false);
	}
	break;
	case LAYER_GMRTS:
	{
		HotkeyMngr_SetGroupState("GMRTS", true);
		HotkeyMngr_SetGroupState("GM", false);
		HotkeyMngr_SetGroupState("GMWASD", false);
		HotkeyMngr_SetGroupState("Main", false);
		HotkeyMngr_SetGroupState("RTS", false);
		HotkeyMngr_SetGroupState("WASD", false);
	}
	break;
	case LAYER_GMWASD:
	{
		HotkeyMngr_SetGroupState("GMWASD", true);
		HotkeyMngr_SetGroupState("GMRTS", false);
		HotkeyMngr_SetGroupState("GM", false);
		HotkeyMngr_SetGroupState("Main", false);
		HotkeyMngr_SetGroupState("RTS", false);
		HotkeyMngr_SetGroupState("WASD", false);
	}
	break;
	default:
	{
		HotkeyMngr_SetGroupState("Main", true);
		HotkeyMngr_SetGroupState("RTS", false);
		HotkeyMngr_SetGroupState("WASD", false);
		HotkeyMngr_SetGroupState("GM", false);
		HotkeyMngr_SetGroupState("GMRTS", false);
		HotkeyMngr_SetGroupState("GMWASD", false);
	}
	break;
	}
}

#endif // CLIENT_HOTKEY_BIND