	HotkeyMngr_AddGroup("GMRTS", false);
	HotkeyMngr_AddGroup("GMWASD", false);

	// Main Hotkeys
	AddMultigroupHotkey(MainGroupsList, "AimNone", DIK_NUMPAD0, AimCallback, array<int> = {HIT_LOCATION_NONE});
