// GUI Flags for Elements
#define GUI_FLAG_DONT_STRETCH	 				( 0x00000001 )	// 1    Don't stretch element's sprite
#define GUI_FLAG_CENTERED					    ( 0x00000002 )	// 2	Draw element's sprite centered
#define GUI_FLAG_MOUSE_PASSTHRU			        ( 0x00000004 )	// 3	Allow mouse clicks to pass thru element
#define GUI_FLAG_DEBUG							( 0x00000008 )	// 4	
#define GUI_FLAG_5								( 0x00000010 )	// 5	
#define GUI_FLAG_6							    ( 0x00000020 )	// 6	
#define GUI_FLAG_7							    ( 0x00000040 )	// 7	
#define GUI_FLAG_8							    ( 0x00000080 )	// 8	
#define GUI_FLAG_9						        ( 0x00000100 )	// 9	
#define GUI_FLAG_10						        ( 0x00000200 )	// 10	
#define GUI_FLAG_11						        ( 0x00000400 )	// 11	
#define GUI_FLAG_12						        ( 0x00000800 )	// 12	
#define GUI_FLAG_13						        ( 0x00001000 )	// 13	
#define GUI_FLAG_14						        ( 0x00002000 )	// 14	
#define GUI_FLAG_15							    ( 0x00004000 )	// 15	
#define GUI_FLAG_16							    ( 0x00008000 )	// 16	
#define GUI_FLAG_17							    ( 0x00010000 )	// 17	
#define GUI_FLAG_18							    ( 0x00020000 )	// 18	
#define GUI_FLAG_19						        ( 0x00040000 )	// 19	
#define GUI_FLAG_20								( 0x00080000 )	// 20	
#define GUI_FLAG_21							    ( 0x00100000 )	// 21	
#define GUI_FLAG_22							    ( 0x00200000 )	// 22	
#define GUI_FLAG_23							    ( 0x00400000 )	// 23	
#define GUI_FLAG_24							    ( 0x00800000 )	// 24	
#define GUI_FLAG_25					            ( 0x01000000 )	// 25	
#define GUI_FLAG_26						        ( 0x02000000 )	// 26	
#define GUI_FLAG_27							    ( 0x04000000 )	// 27	
#define GUI_FLAG_28							    ( 0x08000000 )	// 28	
#define GUI_FLAG_29								( 0x10000000 )	// 29
#define GUI_FLAG_30								( 0x20000000 )	// 30
#define GUI_FLAG_31								( 0x40000000 )	// 31
#define GUI_FLAG_32								( 0x80000000 )	// 32

shared class KeybData
{
    uint8[] Char;     // Russian, Rissian Shift, English, English Shift
    KeybData( int8 r, int8 rs, int8 e, int8 es )
    {
        Char.resize( 4 );
        Char[ 0 ] = r;
        Char[ 1 ] = rs;
        Char[ 2 ] = e;
        Char[ 3 ] = es;
    }
}

shared interface IGUIInstanceContext{}

