funcdef void IGUIScreenInstanceInitFunc( IGUIInstanceContext@ context, IGUIScreenOpt@ screen );
funcdef void IGUIElementInstanceInitFunc( IGUIInstanceContext@ context, IGUIElementOpt@ element );

